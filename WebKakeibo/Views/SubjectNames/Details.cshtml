@model WebKakeibo.Models.SubjectName

@{
    ViewData["Title"] = "科目明細";
}

<h1>科目明細</h1>
<h4 style="color:coral">@TempData["Message"]</h4>
<div>
    <h4>科目名</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CourseName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CourseName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ImageUrl)
        </dt>
        <dd class = "col-sm-10">
           @*  @Html.DisplayFor(model => model.ImageUrl) *@
            <img src="@Url.Content('/' + Model.ImageUrl)" alt=@Model.ImageUrl class="img-thumbnail" style="width:200px;" />
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-info" role="alert" style="width:200px">
                    変更後の画像
                </div>
            }

        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.SubjectNameId">編集</a> |
    <a asp-action="Index">一覧に戻る</a>
</div>
