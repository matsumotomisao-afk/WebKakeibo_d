@model WebKakeibo.Models.MonthlyBudget
@using Microsoft.AspNetCore.Identity  @* Identity関連の名前空間 *@
@inject UserManager<IdentityUser> userManager

@{
    ViewData["Title"] = "月次予算編集";
}

<h1>月次予算編集</h1>

<h4>月次予算</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MonthlyBudgetId" />
            <div class="form-group">
                <label asp-for="YearNum" class="control-label"></label>
                <input asp-for="YearNum" class="form-control" />
                <span asp-validation-for="YearNum" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MonthNum" class="control-label"></label>
                <input asp-for="MonthNum" class="form-control" />
                <span asp-validation-for="MonthNum" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BudgetAmount" class="control-label"></label>
                <input asp-for="BudgetAmount" class="form-control" />
                <span asp-validation-for="BudgetAmount" class="text-danger"></span>
            </div>
            <div class="form-group">
                @* <label asp-for="UserId" class="control-label"></label>
                <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId"></select> *@
                <input type="hidden" asp-for="UserId" class="form-controll" value="@userManager.GetUserId(User)" />
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="保存" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
